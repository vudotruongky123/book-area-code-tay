{
  "name": "vueui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "tunnel": "wait-on http://localhost:5173 && docker run --rm cloudflare/cloudflared:latest tunnel --url http://host.docker.internal:5173",
    "dev:tunnel": "concurrently -k \"npm run dev\" \"npm run tunnel\""
  },
  "dependencies": {
    "axios": "^1.16.1",
    "bootstrap": "^5.3.8",
    "echarts": "^6.0.0",
    "gsap": "^3.15.0",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6",
    "wait-on": "^9.0.10"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
